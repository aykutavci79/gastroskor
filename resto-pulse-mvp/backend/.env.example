APP_NAME=GastroSkor API
ENVIRONMENT=development
API_V1_PREFIX=/api/v1

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/resto_pulse

JWT_SECRET=change-me
JWT_ALGORITHM=HS256

GOOGLE_PLACES_API_KEY=
# Mobil Google Sign-In idToken dogrulama (Web client ID zorunlu; Android/iOS opsiyonel yedek audience)
GOOGLE_OAUTH_WEB_CLIENT_ID=
GOOGLE_OAUTH_ANDROID_CLIENT_ID=
GOOGLE_OAUTH_IOS_CLIENT_ID=
GEMINI_API_KEY=
# Rakip analizi icin onerilir (yoksa heuristic mod calisir)
PLACES_TIMEOUT_MS=10000
PLACES_MAX_REVIEWS=5
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

SMS_PROVIDER=mock
# netgsm | iletimerkezi | mock
NETGSM_USER=
NETGSM_PASSWORD=
NETGSM_HEADER=
ILETIMERKEZI_API_KEY=
ILETIMERKEZI_API_HASH=
# Onayli baslik veya test icin APITEST (sadece kayitli test numarana gider)
ILETIMERKEZI_SENDER=APITEST
OTP_EXPIRY_MINUTES=10
PANEL_ADMIN_SECRET=change-me-panel-admin
# Virgulle: bu Google hesaplari /panel/admin ve bypass kullanir
PANEL_ADMIN_EMAILS=senin@gmail.com
TRIAL_DAYS=30
DEFAULT_AI_ANALYSIS_INTERVAL_DAYS=33

# Panel fiyatlari (TL)
PRICE_PANEL_INTRO_TL=399
PRICE_PANEL_MONTHLY_TL=599
PRICE_EXTRA_AI_TL=199
PRICE_ADDON_WEEKLY_TL=249
PRICE_ADDON_DAILLY_TL=499
# true = satin alma aninda aktif (test); false = iyzico gelene kadar 501
PANEL_PAYMENTS_MOCK=true

# Menu / kapak / yorum fotolari — Railway'de kalici disk ZORUNLU (deploy'da /tmp silinir)
PUBLIC_API_BASE_URL=https://api.gastroskor.com.tr
MENU_UPLOAD_MAX_BYTES=5000000
REVIEW_IMAGE_UPLOAD_MAX_BYTES=8000000

# Secenek A (onerilen baslangic): Railway Volume mount /data → API servisinde:
#   Mount Path: /data
#   MEDIA_DATA_DIR=/data
MEDIA_DATA_DIR=/data

# Secenek B: Cloudflare R2 veya S3 uyumlu bulut (MEDIA_DATA_DIR bos birakilabilir)
# MEDIA_STORAGE=s3
# S3_BUCKET=gastroskor-media
# S3_ENDPOINT_URL=https://ACCOUNT_ID.r2.cloudflarestorage.com
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_BASE_URL=https://pub-XXXX.r2.dev
# S3_REGION=auto

PUBLIC_SITE_BASE_URL=https://www.gastroskor.com.tr
PUBLIC_PANEL_BASE_URL=https://www.gastroskor.com.tr/panel
REVIEW_IMAGE_MAX_EDGE_PX=1280

# E-posta bildirimleri (mock = log; smtp = gercek gonderim)
EMAIL_PROVIDER=mock
EMAIL_FROM=noreply@gastroskor.com.tr
# Guzel Hosting ornek: mt-pegasus.guzelhosting.com port 465 (SSL)
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=destek@gastroskor.com.tr
SMTP_PASSWORD=
SMTP_USE_TLS=true

# Cron endpoint korumasi (/api/v1/internal/cron/panel-notifications)
CRON_SECRET=change-me-cron-secret

# Gunluk KPI e-postasi (bos = PANEL_ADMIN_EMAILS). Vercel cron: 05:00 UTC = 08:00 TR
# METRICS_DAILY_REPORT_EMAILS=coolisback@gmail.com

# Gurme sohbet asistani (saniye) — LLM yok, sablon + DB
GOURMET_ASSISTANT_ENABLED=true
GOURMET_ASSISTANT_GREETING_DELAY_SEC=180
GOURMET_ASSISTANT_FOLLOWUP_DELAY_SEC=60
GOURMET_ASSISTANT_ROOM_COOLDOWN_SEC=1800
GOURMET_ASSISTANT_MAX_PER_ROOM_HOUR=3
GOURMET_ASSISTANT_MAX_PER_USER_DAY=5
GOURMET_ASSISTANT_ROOM_MAX_MSG_PER_HOUR=20
# GEMINI_API_KEY doluysa cevaplari samimilesir (Grok tarzi ton); yoksa sadece sablon
GOURMET_ASSISTANT_GEMINI_PERSONALITY=true

# Gurme BilBakalim trivia botu (saniye)
GOURMET_TRIVIA_ENABLED=true
GOURMET_TRIVIA_INTERVAL_SEC=180
GOURMET_TRIVIA_ANSWER_WINDOW_SEC=90

# Yorum, DM, gurme sohbet argo/kufur filtresi (true = acik). Simdilik kapali birakilabilir.
CONTENT_MODERATION_ENABLED=false

