APP_NAME=GastroSkor API
ENVIRONMENT=development
API_V1_PREFIX=/api/v1

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/resto_pulse

JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_HOURS=2
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
# production'da true (varsayilan); lokal gelistirmede false yapabilirsiniz
AUTH_REQUIRE_BEARER=false

GOOGLE_PLACES_API_KEY=
# Kart/liste Google foto (Places Photo ucreti). Varsayilan kapali; acmak icin true
GOOGLE_CARD_PHOTOS_ENABLED=false
# Mobil Google Sign-In idToken dogrulama (Web client ID zorunlu; Android/iOS opsiyonel yedek audience)
GOOGLE_OAUTH_WEB_CLIENT_ID=
# Google Isletme baglantisi (OAuth code flow) — Cloud Console Web client secret
GOOGLE_OAUTH_WEB_CLIENT_SECRET=
GOOGLE_OAUTH_ANDROID_CLIENT_ID=
GOOGLE_OAUTH_IOS_CLIENT_ID=
GEMINI_API_KEY=
# Rakip analizi icin onerilir (yoksa heuristic mod calisir)
PLACES_TIMEOUT_MS=10000
PLACES_MAX_REVIEWS=5
OPENAI_API_KEY=
# Sesli siparis STT — Groq birincil, OpenAI yedek (POST /api/v1/voice/transcribe)
GROQ_API_KEY=
VOICE_TRANSCRIBE_GROQ_MODEL=whisper-large-v3-turbo
VOICE_TRANSCRIBE_OPENAI_MODEL=gpt-4o-mini-transcribe
VOICE_TRANSCRIBE_MAX_BYTES=5000000
VOICE_TRANSCRIBE_TIMEOUT_SEC=25
ANTHROPIC_API_KEY=

SMS_PROVIDER=mock
# netgsm | iletimerkezi | mock
NETGSM_USER=
NETGSM_PASSWORD=
NETGSM_HEADER=
ILETIMERKEZI_API_KEY=
ILETIMERKEZI_API_HASH=
# Onayli baslik veya test icin APITEST (sadece kayitli test numarana gider)
ILETIMERKEZI_SENDER=APITEST
OTP_EXPIRY_MINUTES=10
# OTP hash pepper — production'da guclu rastgele deger (HMAC-SHA256)
OTP_PEPPER=
# Siparis testi: bu numaralar SMS OTP atlanir (virgulle, 05xx veya +90)
ORDER_PHONE_TEST_BYPASS=05323971194,05497951492,05384452282,05551757719,05061814314,05536531949,05497480319,05395683779
PANEL_ADMIN_SECRET=change-me-panel-admin
# Virgulle: bu Google hesaplari /panel/admin ve bypass kullanir
PANEL_ADMIN_EMAILS=senin@gmail.com
TRIAL_DAYS=30
DEFAULT_AI_ANALYSIS_INTERVAL_DAYS=33

# Panel fiyatlari (TL)
PRICE_PANEL_INTRO_TL=399
PRICE_PANEL_MONTHLY_TL=599
PRICE_EXTRA_AI_TL=199
PRICE_ADDON_WEEKLY_TL=249
PRICE_ADDON_DAILLY_TL=499
# true = satin alma aninda aktif (test); false = iyzico gelene kadar 501
PANEL_PAYMENTS_MOCK=true

# Menu / kapak / yorum fotolari — Railway'de kalici disk ZORUNLU (deploy'da /tmp silinir)
PUBLIC_API_BASE_URL=https://api.gastroskor.com.tr
MENU_UPLOAD_MAX_BYTES=5000000
REVIEW_IMAGE_UPLOAD_MAX_BYTES=8000000

# Secenek A (onerilen baslangic): Railway Volume mount /data → API servisinde:
#   Mount Path: /data
#   MEDIA_DATA_DIR=/data
MEDIA_DATA_DIR=/data

# Secenek B: Cloudflare R2 veya S3 uyumlu bulut (MEDIA_DATA_DIR bos birakilabilir)
# MEDIA_STORAGE=s3
# S3_BUCKET=gastroskor-media
# S3_ENDPOINT_URL=https://ACCOUNT_ID.r2.cloudflarestorage.com
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_BASE_URL=https://pub-XXXX.r2.dev
# S3_REGION=auto

PUBLIC_SITE_BASE_URL=https://www.gastroskor.com.tr
PUBLIC_PANEL_BASE_URL=https://www.gastroskor.com.tr/panel
REVIEW_IMAGE_MAX_EDGE_PX=1280

# E-posta bildirimleri (mock = log; smtp = gercek gonderim)
EMAIL_PROVIDER=mock
EMAIL_FROM=noreply@gastroskor.com.tr
# Guzel Hosting ornek: mt-pegasus.guzelhosting.com port 465 (SSL)
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=destek@gastroskor.com.tr
SMTP_PASSWORD=
SMTP_USE_TLS=true

# Cron endpoint korumasi (/api/v1/internal/cron/panel-notifications)
CRON_SECRET=change-me-cron-secret
# Haftalik: POST /api/v1/internal/cron/sofra-kelime-adaylari (X-Cron-Secret)
# Gunluk 16:30 TR (13:30 UTC): GitHub Actions → sofra-bulmaca-import
# SOFRA_HAVUZ_JSON_PATH=app/data/kelime_sofrasi_havuz.json
# SOFRA_MOBILE_ROOT=../mobile
# Sentry — backend ayri proje (mobil EXPO_PUBLIC_SENTRY_DSN'den farkli)
# Railway Variables: SENTRY_DSN=https://<public-key>@o<org-id>.ingest.de.sentry.io/<project-id>
SENTRY_DSN=
# Performance orneklemesi: 0.1 = trafikten %10 (production varsayilan)
SENTRY_TRACES_SAMPLE_RATE=0.1
# SOFRA_TDK_JSON_PATH=/path/to/tdk.json
# SOFRA_ATTEMPT_MIN_COUNT=3

# Gunluk KPI e-postasi (bos = PANEL_ADMIN_EMAILS). Vercel cron: 05:00 UTC = 08:00 TR
# METRICS_DAILY_REPORT_EMAILS=coolisback@gmail.com

# Gurme sohbet asistani (saniye) — LLM yok, sablon + DB
GOURMET_ASSISTANT_ENABLED=true
GOURMET_ASSISTANT_GREETING_DELAY_SEC=180
GOURMET_ASSISTANT_FOLLOWUP_DELAY_SEC=60
GOURMET_ASSISTANT_ROOM_COOLDOWN_SEC=1800
GOURMET_ASSISTANT_MAX_PER_ROOM_HOUR=3
GOURMET_ASSISTANT_MAX_PER_USER_DAY=5
GOURMET_ASSISTANT_ROOM_MAX_MSG_PER_HOUR=20
# GEMINI_API_KEY doluysa cevaplari samimilesir (Grok tarzi ton); yoksa sadece sablon
GOURMET_ASSISTANT_GEMINI_PERSONALITY=true

# Gurme BilBakalim trivia botu (saniye)
GOURMET_TRIVIA_ENABLED=true
GOURMET_TRIVIA_INTERVAL_SEC=180
GOURMET_TRIVIA_ANSWER_WINDOW_SEC=90

# Sosyal kanit (POST /api/v1/discover/search) — Groq sentiment + last30days tarama
SOCIAL_PROOF_GROQ_MODEL=llama-3.1-8b-instant
SOCIAL_PROOF_GROQ_TIMEOUT_SEC=30
SOCIAL_PROOF_SCAN_TIMEOUT_SEC=120
# Lokal test: last30days yerine mock mention
# Lokal web testinde rozet gormek icin true yapin (Google mekan adlariyla mock mention)
SOCIAL_PROOF_SCAN_MOCK=false
# Topluluk sinyali (Ekşi) — entry metni UI'da gosterilmez, yalnizca sayim
SOCIAL_PROOF_EKSI_ENABLED=true
SOCIAL_PROOF_EKSI_TIMEOUT_SEC=20
SOCIAL_PROOF_EKSI_MAX_TOPICS=6
SOCIAL_PROOF_EKSI_MAX_ENTRIES=50
# Opsiyonel: last30days.py tam yolu (varsayilan ~/.agents/skills/last30days/scripts/last30days.py)
SOCIAL_PROOF_LAST30DAYS_SCRIPT=
SOCIAL_PROOF_LAST30DAYS_PYTHON=

# Yorum, DM, gurme sohbet argo/kufur filtresi (true = acik). Simdilik kapali birakilabilir.
CONTENT_MODERATION_ENABLED=false

# Rate limiting — Railway Redis template (REDIS_URL) veya Upstash; yoksa in-memory fallback
# Ornek: redis://default:password@redis.railway.internal:6379
REDIS_URL=
# Railway Redis internal URL (REDIS_URL bos ise kullanilir)
REDIS_PRIVATE_URL=
RATE_LIMIT_REDIS_KEY_PREFIX=gastroskor:rl
# JWT'li kullanici basina tum API cap (dakika)
RATE_LIMIT_USER_GLOBAL_PER_MINUTE=100
RATE_LIMIT_USER_GLOBAL_WINDOW_SEC=60

