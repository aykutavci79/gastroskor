NEXT_PUBLIC_API_URL=https://api.gastroskor.com.tr

# Canonical site URL (sitemap, Open Graph, Google Search Console)
NEXT_PUBLIC_SITE_URL=https://www.gastroskor.com.tr

# Universal / App Links (Android dogrulama — virgulle birden fazla SHA-256)
# eas credentials -p android + Play Console App signing key
# ANDROID_SHA256_FINGERPRINTS=AB:CD:...:EF

# Google Search Console -> Ownership verification -> HTML tag (meta name="google-site-verification")
# GOOGLE_SITE_VERIFICATION=

# --- NextAuth (panel Google girisi icin zorunlu) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://www.gastroskor.com.tr
# Vercel/canli (NextAuth v4 — trustHost kodda degil):
AUTH_TRUST_HOST=true

# Panel admin (sadece bu Google hesaplari /panel/admin gorur)
PANEL_ADMIN_EMAILS=senin@gmail.com
PANEL_ADMIN_SECRET=

# Local panel + kupon testi:
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
# Google Cloud Web client -> Authorized redirect URIs:
#   http://localhost:3000/api/auth/callback/google
# Authorized JavaScript origins:
#   http://localhost:3000
# Detay: frontend/LOCAL_PANEL.md
