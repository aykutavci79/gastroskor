{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "functions": {
    "app/api/panel/admin/seed-tester-restaurants/route.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/panel-notifications",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/metrics-daily-report",
      "schedule": "0 5 * * *"
    }
  ]
}
