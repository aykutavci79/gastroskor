{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/panel-notifications",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/gourmet-chat-assistant",
      "schedule": "*/3 * * * *"
    },
    {
      "path": "/api/cron/gourmet-trivia",
      "schedule": "*/3 * * * *"
    }
  ]
}
