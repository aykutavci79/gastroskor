{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/panel-notifications",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/reservation-expirations",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/metrics-daily-report",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/sofra-kelime-adaylari",
      "schedule": "0 7 * * 0"
    }
  ]
}
