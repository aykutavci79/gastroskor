{
  "cli": {
    "version": ">= 14.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.gastroskor.com.tr",
        "EXPO_PUBLIC_SITE_URL": "https://www.gastroskor.com.tr"
      },
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      }
    },
    "production": {
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.gastroskor.com.tr",
        "EXPO_PUBLIC_SITE_URL": "https://www.gastroskor.com.tr"
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-play-service-account.json",
        "track": "internal"
      },
      "ios": {
        "appleId": "coolisback@gmail.com",
        "ascAppId": "6776410673",
        "appleTeamId": "5XTXAT7BXZ"
      }
    }
  }
}
