{
  "name": "gastroskor-mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "node ./scripts/expo-start-skip-doctor.js",
    "start:clean": "node ./scripts/expo-start-skip-doctor.js -c --port 8081",
    "start:lan": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-expo-lan.ps1",
    "start:tunnel": "node ./scripts/expo-start-skip-doctor.js -c --tunnel",
    "metro:kill": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/metro-port-temizle.ps1",
    "setup:metro:firewall": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/firewall-expo.ps1",
    "android": "node ./scripts/expo-start-skip-doctor.js --android",
    "ios": "node ./scripts/expo-start-skip-doctor.js --ios",
    "web": "node ./scripts/expo-start-skip-doctor.js --web",
    "lint": "expo lint",
    "build:lexicon": "node ./scripts/build-gastro-lexicon.mjs",
    "build:android:preview": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/eas-build-preview.ps1",
    "build:android:prod": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/eas-build-prod.ps1 -Platform android",
    "build:ios:prod": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/eas-build-prod.ps1 -Platform ios",
    "build:prod": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/eas-build-release.ps1",
    "build:prod:submit": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/eas-build-release.ps1 -Submit",
    "build:prod:ios-only": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/eas-build-release.ps1 -SkipSecond",
    "release:check": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/eas-release-preflight.ps1",
    "release:check:apply": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/eas-release-preflight.ps1 -Apply",
    "preflight:code": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/run-code-preflight.ps1 -SkipExport",
    "preflight:full": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/run-code-preflight.ps1",
    "verify:voice-stt": "node ./scripts/verify-voice-stt-fixes.mjs",
    "test:sentry-scrub": "node --experimental-strip-types --test ./lib/sentry-scrub.test.ts",
    "test:voice-prepare": "node --experimental-strip-types --test ./lib/voice-prepare-guard.test.ts",
    "test:sofra-engine": "npx tsx --test ./lib/kelime-sofrasi/engine.test.ts",
    "generate:sofra-bank": "npx tsx scripts/generate-sofra-bank.ts",
    "postinstall": "node ./scripts/prune-nested-react-native.js",
    "build:android:prod:safe": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/eas-release-preflight.ps1 -AndroidOnly -Apply; powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/eas-build-prod.ps1 -Platform android",
    "setup:android": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/setup-android-build-windows.ps1",
    "setup:android:env": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/install-android-env-windows.ps1",
    "setup:android:keystore": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/create-android-keystore.ps1",
    "setup:ios": "bash ./scripts/setup-ios-build-mac.sh",
    "release:local:check": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/release-preflight-local.ps1",
    "release:local:check:apply": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/release-preflight-local.ps1 -Apply",
    "build:android:local": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/build-android-local.ps1",
    "build:android:local:apk": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/build-android-local.ps1 -Apk",
    "migrate:short-path": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/migrate-to-c-dev-gs.ps1",
    "migrate:short-path:build": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/migrate-to-c-dev-gs.ps1 -RunBuild",
    "submit:android:local": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/submit-android-local.ps1",
    "build:ios:local": "bash ./scripts/build-ios-local-mac.sh --apply-preflight"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@posthog/core": "^1.35.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/native": "^7.1.8",
    "@sentry/react-native": "~7.2.0",
    "expo": "~54.0.33",
    "expo-application": "~7.0.8",
    "expo-av": "~16.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.11",
    "expo-localization": "~17.0.9",
    "expo-location": "~19.0.8",
    "expo-notifications": "^0.32.17",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-speech": "~14.0.8",
    "expo-speech-recognition": "^3.1.3",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.11",
    "posthog-react-native": "^4.50.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-controller": "1.18.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-ssl-public-key-pinning": "^1.2.6",
    "react-native-svg": "^15.12.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "overrides": {
    "react-native": "0.81.5"
  },
  "devDependencies": {
    "@emnapi/core": "^1.10.0",
    "@emnapi/runtime": "^1.10.0",
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.1.0",
    "babel-preset-expo": "~54.0.11",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "typescript": "~5.9.2"
  }
}
