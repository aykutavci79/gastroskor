# Canli API (Railway) — telefon/TestFlight icin varsayilan
EXPO_PUBLIC_API_URL=https://api.gastroskor.com.tr
# Yerel backend testi (uvicorn + docker postgres): bilgisayar LAN IP, ornek:
# EXPO_PUBLIC_API_URL=http://192.168.1.10:8000
EXPO_PUBLIC_SITE_URL=https://www.gastroskor.com.tr

# Google Places kart fotolari (Places Photo ucreti). Varsayilan kapali.
# EXPO_PUBLIC_GOOGLE_CARD_PHOTOS=true

# Google Sign-In Native SDK — Cloud Console > Credentials
# Web client ID ZORUNLU (Android idToken icin). Expo Go'da Google calismaz; EAS build kullanin.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Expo Go gelistirici girisi — canli API'de Railway DEV_LOGIN_SECRET ile ayni deger
# EXPO_PUBLIC_DEV_LOGIN_SECRET=

# eas init sonrasi proje ID (app.config.js extra.eas.projectId)
EAS_PROJECT_ID=f1b0f615-fade-46b5-8bd2-fe6d61a9ad1e

# Sentry crash reporting (mobil production build)
EXPO_PUBLIC_SENTRY_DSN=
# EAS build'de source map upload icin (opsiyonel, EAS secret olarak da verilebilir)
# SENTRY_AUTH_TOKEN=

# SSL certificate pinning (yalnizca production EAS build; Expo Go ve __DEV__ kapali)
EXPO_PUBLIC_SSL_PINNING_ENABLED=false
# SPKI SHA-256 base64 pinleri (primary + backup; sertifika rotasyonu icin ikisi de gerekli)
EXPO_PUBLIC_API_SSL_PIN_PRIMARY=
EXPO_PUBLIC_API_SSL_PIN_BACKUP=
