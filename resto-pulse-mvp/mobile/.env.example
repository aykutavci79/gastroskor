# Canli API (Railway) — telefon/TestFlight icin varsayilan
EXPO_PUBLIC_API_URL=https://api.gastroskor.com.tr
# Yerel backend testi (uvicorn + docker postgres): bilgisayar LAN IP, ornek:
# EXPO_PUBLIC_API_URL=http://192.168.1.10:8000
EXPO_PUBLIC_SITE_URL=https://www.gastroskor.com.tr

# Google OAuth — Cloud Console > APIs & Services > Credentials
# Expo Go icin ZORUNLU: Web client ID + asagidaki redirect URI Cloud Console'a ekli olmali:
#   https://auth.expo.io/@delimanyah/gastroskor
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
# Expo Go / gelistirme — Android client ZORUNLU (Web ID Android'de kullanilamaz)
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Expo Go icin (Web client redirect URI listesine de ekleyin)
EXPO_PUBLIC_EXPO_AUTH_REDIRECT=https://auth.expo.io/@delimanyah/gastroskor

# eas init sonrasi proje ID (app.config.js extra.eas.projectId)
# Expo @delimanyah/gastroskor (app.config.js icinde varsayilan da var)
EAS_PROJECT_ID=3009c65b-6419-4567-a859-363698cf6880
